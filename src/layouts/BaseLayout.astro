---
interface Props {
  title: string;
  description?: string;
  activeNav?: 'all' | 'note' | 'reading' | 'photo' | 'link' | 'search' | 'graph';
}

const { title, description = 'stash — 断片のための場所', activeNav = 'all' } = Astro.props;

const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

const navItems: { key: NonNullable<Props['activeNav']>; label: string; href: string }[] = [
  { key: 'all', label: 'all', href: '/' },
  { key: 'note', label: 'note', href: '/note/' },
  { key: 'reading', label: 'reading', href: '/reading/' },
  { key: 'photo', label: 'photo', href: '/photo/' },
  { key: 'link', label: 'link', href: '/link/' },
  { key: 'graph', label: 'graph', href: '/graph/' },
  { key: 'search', label: 'search', href: '/search/' },
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
      />
    )}
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a href="/" class="logo">stash</a>
        <nav class="nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={['nav-link', { active: item.key === activeNav }]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </header>
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fafaf7;
    --surface: #ffffff;
    --ink: #111111;
    --ink-soft: #333333;
    --muted: #6b685e;
    --faint: #b0ada3;
    --faintest: #c4c1b6;
    --hairline: #eae8e1;
    --note: #4a7c59;
    --reading: #3a5f8a;
    --photo: #8a6f3a;
    --link: #7a5a8a;
    --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    --sans: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP',
      'Segoe UI', Roboto, sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  a,
  a:visited {
    color: inherit;
    text-decoration: none;
  }
</style>

<style>
  .shell {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 32px 96px;
  }
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }
  .logo {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .nav {
    display: flex;
    gap: 20px;
  }
  .nav-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
    transition: color 0.15s ease;
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-link.active {
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .shell {
      padding: 32px 20px 64px;
    }
    .site-header {
      margin-bottom: 28px;
    }
    .nav {
      gap: 14px;
    }
  }
</style>
