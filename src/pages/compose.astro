---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="compose — stash">
  <Fragment slot="head">
    <meta http-equiv="refresh" content="0; url=/compose/note" />
  </Fragment>
  <div class="compose">
    <p>redirecting…</p>
    <p><a href="/compose/note">/compose/note</a></p>
  </div>
  <script is:inline>
    location.replace('/compose/note');
  </script>
</BaseLayout>

<style>
  .compose {
    padding: 80px 0;
    text-align: center;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--faint);
  }
  .compose a {
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
  }
</style>
