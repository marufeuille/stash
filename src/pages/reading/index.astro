---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StreamItem from '../../components/StreamItem.astro';
import { excerpt } from '../../lib/excerpt';

const posts = (await getCollection('reading'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="reading — stash" activeNav="reading">
  <main class="stream">
    {posts.map((post) => (
      <StreamItem
        type="reading"
        href={`/reading/${post.id}/`}
        title={post.data.title ?? post.data.book}
        date={post.data.date}
        tags={post.data.tags}
        book={post.data.book}
        author={post.data.author}
        progress={post.data.progress}
        excerpt={excerpt(post.body)}
      />
    ))}
  </main>
</BaseLayout>

<style>
  .stream { border-bottom: 1px solid var(--hairline); }
</style>
