---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StreamItem from '../components/StreamItem.astro';
import { excerpt } from '../lib/excerpt';

let recentSummary: { text: string | null; count: number } | null = null;
try {
  recentSummary = (await import('../data/recent-summary.json')).default;
} catch {
  recentSummary = null;
}

const photos = await getCollection('photo');
const readings = await getCollection('reading');
const notes = await getCollection('note');

const allPosts = [...photos, ...readings, ...notes]
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const aboutEntry = await getEntry('meta', 'about');
const AboutContent = aboutEntry ? (await render(aboutEntry)).Content : null;
const aboutTitle = aboutEntry?.data.title ?? 'about stash';
---

<BaseLayout title="stash" activeNav="all">
  {recentSummary?.text && (
    <aside class="recent-summary" aria-label="recent summary">
      <span class="recent-summary-label">lately</span>
      <p class="recent-summary-text">{recentSummary.text}</p>
    </aside>
  )}
  <a id="capture" class="capture" href="#" aria-disabled="true" tabindex="-1">
    <span class="capture-prompt">+ stash a fragment…</span>
    <span class="capture-hint">⌘N</span>
  </a>

  <div id="about-overlay" class="overlay" hidden aria-hidden="true">
    <div class="overlay-backdrop" data-close></div>
    <div class="overlay-panel" role="dialog" aria-modal="true" aria-labelledby="about-title">
      <button class="overlay-close" type="button" data-close aria-label="close">×</button>
      <div class="overlay-meta">
        <span class="overlay-type">about</span>
      </div>
      <h2 id="about-title" class="overlay-title">{aboutTitle}</h2>
      <div class="overlay-body">
        {AboutContent ? <AboutContent /> : <p class="overlay-empty">about.md がvaultにまだありません。</p>}
      </div>
    </div>
  </div>
  <script is:inline>
    (function () {
      var el = document.getElementById('capture');
      if (!el) return;
      var params = new URLSearchParams(location.search);
      if (params.get('own') === '1') {
        localStorage.setItem('stashOwner', '1');
        history.replaceState(null, '', location.pathname);
      }
      var isOwner = localStorage.getItem('stashOwner') === '1';
      var overlay = document.getElementById('about-overlay');
      function openAbout() {
        if (!overlay) return;
        overlay.hidden = false;
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function closeAbout() {
        if (!overlay) return;
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
      if (overlay) {
        overlay.addEventListener('click', function (e) {
          if (e.target instanceof Element && e.target.hasAttribute('data-close')) {
            closeAbout();
          }
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !overlay.hidden) closeAbout();
        });
      }
      if (!isOwner) {
        el.addEventListener('click', function (e) {
          e.preventDefault();
          openAbout();
        });
        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'n') {
            e.preventDefault();
            openAbout();
          }
        });
        return;
      }
      el.removeAttribute('aria-disabled');
      el.removeAttribute('tabindex');
      el.classList.add('is-active');
      function pad(n) { return String(n).padStart(2, '0'); }
      function buildHref() {
        var d = new Date();
        var name =
          d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) +
          '_' + pad(d.getHours()) + '-' + pad(d.getMinutes()) + '-' + pad(d.getSeconds());
        var dateStr =
          d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        var content =
          '---\n' +
          'type: note\n' +
          'title: ""\n' +
          'date: ' + dateStr + '\n' +
          'tags: []\n' +
          'draft: true\n' +
          '---\n\n';
        return 'obsidian://new?vault=stash&file=' +
          encodeURIComponent('note/' + name) +
          '&content=' + encodeURIComponent(content);
      }
      el.addEventListener('click', function (e) {
        el.href = buildHref();
      });
      document.addEventListener('keydown', function (e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'n') {
          e.preventDefault();
          el.href = buildHref();
          location.href = el.href;
        }
      });
    })();
  </script>
  <main class="stream">
    {allPosts.map((post) => {
      const d = post.data;
      if (d.type === 'photo') {
        return (
          <StreamItem
            type="photo"
            href={`/photo/${post.id}/`}
            title={d.title ?? 'Untitled'}
            date={d.date}
            tags={d.tags}
            image={d.image}
            alt={d.alt}
          />
        );
      }
      if (d.type === 'reading') {
        return (
          <StreamItem
            type="reading"
            href={`/reading/${post.id}/`}
            title={d.title ?? d.book}
            date={d.date}
            tags={d.tags}
            book={d.book}
            author={d.author}
            progress={d.progress}
            excerpt={excerpt(post.body)}
          />
        );
      }
      return (
        <StreamItem
          type="note"
          href={`/note/${post.id}/`}
          title={d.title ?? 'Untitled'}
          date={d.date}
          tags={d.tags}
          excerpt={excerpt(post.body)}
        />
      );
    })}
  </main>
</BaseLayout>

<style>
  .recent-summary {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 14px 2px 18px;
    margin-bottom: 10px;
    border-bottom: 1px dashed var(--hairline);
  }
  .recent-summary-label {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--faint);
    flex-shrink: 0;
  }
  .recent-summary-text {
    font-size: 13px;
    line-height: 1.7;
    color: var(--muted);
  }
  @media (max-width: 600px) {
    .recent-summary {
      flex-direction: column;
      gap: 4px;
    }
  }
  .capture {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    margin-bottom: 24px;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .capture[aria-disabled='true'] {
    cursor: default;
  }
  .capture.is-active:hover {
    border-color: var(--faint);
  }
  .capture-prompt {
    font-size: 14px;
    color: var(--faint);
  }
  .capture-hint {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faintest);
  }
  .stream {
    border-bottom: 1px solid var(--hairline);
  }

  .overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .overlay[hidden] {
    display: none;
  }
  .overlay-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: fade 0.2s ease;
  }
  .overlay-panel {
    position: relative;
    width: 100%;
    max-width: 560px;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    background: var(--bg);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    padding: 40px 36px 36px;
    box-shadow: 0 20px 60px rgba(17, 17, 17, 0.18);
    animation: rise 0.2s ease;
  }
  .overlay-close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: transparent;
    border: none;
    font-size: 22px;
    line-height: 1;
    color: var(--faint);
    cursor: pointer;
    padding: 4px 8px;
  }
  .overlay-close:hover {
    color: var(--ink);
  }
  .overlay-meta {
    margin-bottom: 8px;
  }
  .overlay-type {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }
  .overlay-title {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.005em;
    margin-bottom: 18px;
  }
  .overlay-body {
    padding-top: 18px;
    border-top: 1px solid var(--hairline);
    font-size: 14px;
    line-height: 1.85;
    color: var(--ink-soft);
  }
  .overlay-body :global(p) { margin: 12px 0; }
  .overlay-body :global(h2) {
    margin: 24px 0 10px;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
  }
  .overlay-body :global(h3) {
    margin: 18px 0 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }
  .overlay-body :global(a) {
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
  }
  .overlay-body :global(a:hover) {
    border-bottom-color: var(--ink);
  }
  .overlay-body :global(blockquote) {
    border-left: 2px solid var(--hairline);
    margin: 14px 0;
    padding: 4px 14px;
    color: var(--muted);
    font-style: italic;
  }
  .overlay-body :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--surface);
    padding: 2px 5px;
    border-radius: 2px;
  }
  .overlay-empty {
    color: var(--faint);
    font-family: var(--mono);
    font-size: 13px;
  }

  @keyframes fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes rise {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
