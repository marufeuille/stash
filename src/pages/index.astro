---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CardPhoto from '../components/CardPhoto.astro';
import CardReading from '../components/CardReading.astro';
import CardNote from '../components/CardNote.astro';

const photos = await getCollection('photo');
const readings = await getCollection('reading');
const notes = await getCollection('note');

const allPosts = [...photos, ...readings, ...notes]
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="stash">
  <header>
    <h1>stash</h1>
    <p class="post-count">{allPosts.length} posts</p>
  </header>
  <main>
    <ul class="card-list">
      {allPosts.map((post) => (
        <li>
          {post.data.type === 'photo' && (
            <CardPhoto
              id={post.id}
              title={post.data.title}
              date={post.data.date}
              image={post.data.image}
              alt={post.data.alt}
              tags={post.data.tags}
            />
          )}
          {post.data.type === 'reading' && (
            <CardReading
              id={post.id}
              title={post.data.title}
              date={post.data.date}
              book={post.data.book}
              author={post.data.author}
              progress={post.data.progress}
              tags={post.data.tags}
            />
          )}
          {post.data.type === 'note' && (
            <CardNote
              id={post.id}
              title={post.data.title}
              date={post.data.date}
              tags={post.data.tags}
            />
          )}
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  header {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 16px 16px;
  }
  h1 {
    font-size: 1.5rem;
  }
  .post-count {
    font-size: 0.85rem;
    color: #888;
  }
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 16px 32px;
  }
  .card-list {
    list-style: none;
    display: grid;
    gap: 16px;
  }
</style>
