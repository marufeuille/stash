---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StreamItem from '../../components/StreamItem.astro';
import RecentSummary from '../../components/RecentSummary.astro';
import { excerpt } from '../../lib/excerpt';
import { sortPostsDesc } from '../../lib/sortPosts';

const posts = sortPostsDesc(
  (await getCollection('note')).filter((p) => !p.data.draft),
);
---

<BaseLayout title="note — stash" activeNav="note">
  <RecentSummary scope="note" />
  <main class="stream">
    {posts.map((post) => (
      <StreamItem
        type="note"
        href={`/note/${post.id}/`}
        title={post.data.title ?? 'Untitled'}
        date={post.data.date}
        tags={post.data.tags}
        excerpt={excerpt(post.body)}
        topic={post.data.topic}
        stage={post.data.stage}
      />
    ))}
  </main>
</BaseLayout>

<style>
  .stream {
    border-bottom: 1px solid var(--hairline);
  }
</style>
