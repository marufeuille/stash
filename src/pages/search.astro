---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="search — stash" activeNav="search">
  <div class="search-box">
    <span class="search-icon">⌕</span>
    <input
      id="q"
      type="search"
      placeholder="search fragments…"
      autocomplete="off"
      autofocus
    />
    <span class="search-hint">
      <span id="count">—</span>
    </span>
  </div>

  <main class="stream" id="results"></main>

  <p class="empty" id="empty" hidden>no fragments match.</p>
  <p class="loading" id="loading">loading index…</p>
</BaseLayout>

<script>
  import MiniSearch from 'minisearch';
  import { tokenize } from '../lib/searchTokenize';

  type Entry = {
    id: string;
    type: 'note' | 'reading' | 'photo' | 'link';
    href: string;
    title: string;
    date: string;
    tags: string[];
    excerpt: string;
    source?: string;
    body: string;
  };

  const input = document.getElementById('q') as HTMLInputElement;
  const results = document.getElementById('results')!;
  const count = document.getElementById('count')!;
  const empty = document.getElementById('empty')!;
  const loading = document.getElementById('loading')!;

  let entries: Entry[] = [];
  let byId = new Map<string, Entry>();
  let mini: MiniSearch<Entry> | null = null;

  function escapeHtml(s: string): string {
    return s.replace(
      /[&<>"']/g,
      (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!),
    );
  }

  function render(list: Entry[]): void {
    if (list.length === 0) {
      results.innerHTML = '';
      empty.hidden = false;
      return;
    }
    empty.hidden = true;
    results.innerHTML = list
      .map((e) => {
        const meta =
          (e.type === 'reading' || e.type === 'link') && e.source
            ? `<span class="source">${escapeHtml(e.source)}</span>`
            : e.tags.length
              ? `<span class="tags">${escapeHtml(e.tags.join('  '))}</span>`
              : '';
        const body = e.excerpt ? `<p class="excerpt">${escapeHtml(e.excerpt)}</p>` : '';
        return `
          <a href="${e.href}" class="item">
            <div class="meta">
              <div class="meta-left">
                <span class="type type-${e.type}">${e.type}</span>
                ${meta}
              </div>
              <time>${e.date}</time>
            </div>
            <h2 class="title">${escapeHtml(e.title)}</h2>
            ${body}
          </a>
        `;
      })
      .join('');
  }

  function update(): void {
    if (!mini) return;
    const q = input.value.trim();
    let list: Entry[];
    if (!q) {
      list = entries;
    } else {
      const hits = mini.search(q);
      list = hits.map((h) => byId.get(String(h.id))!).filter(Boolean);
    }
    count.textContent = String(list.length);
    render(list);
  }

  async function init(): Promise<void> {
    const res = await fetch('/search-index.json');
    entries = (await res.json()) as Entry[];
    byId = new Map(entries.map((e) => [e.id, e]));

    mini = new MiniSearch<Entry>({
      idField: 'id',
      fields: ['title', 'tags', 'source', 'body'],
      storeFields: ['id'],
      tokenize: (text) => tokenize(text),
      processTerm: (t) => t,
      extractField: (doc, fieldName) => {
        const v = (doc as unknown as Record<string, unknown>)[fieldName];
        if (Array.isArray(v)) return v.join(' ');
        return typeof v === 'string' ? v : '';
      },
      searchOptions: {
        boost: { title: 3, tags: 2, source: 2, body: 1 },
        fuzzy: 0.2,
        prefix: true,
        combineWith: 'AND',
      },
    });
    mini.addAll(entries);

    loading.hidden = true;
    count.textContent = String(entries.length);
    update();
  }

  input.addEventListener('input', update);
  init().catch((err) => {
    loading.textContent = 'failed to load index.';
    console.error(err);
  });
</script>

<style>
  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    margin-bottom: 28px;
  }
  .search-icon {
    font-family: var(--mono);
    font-size: 16px;
    color: var(--faint);
  }
  #q {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font: inherit;
    font-size: 15px;
    color: var(--ink);
  }
  #q::placeholder {
    color: var(--faint);
  }
  .search-hint {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faintest);
  }
  .stream {
    border-bottom: 1px solid var(--hairline);
  }
  .stream:empty {
    border-bottom: none;
  }
  .empty,
  .loading {
    padding: 48px 0;
    text-align: center;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
  }

  .stream :global(.item) {
    display: block;
    padding: 24px 0;
    border-top: 1px solid var(--hairline);
    color: var(--ink);
  }
  .stream :global(.item:hover) {
    background: rgba(255, 255, 255, 0.5);
  }
  .stream :global(.meta) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 8px;
  }
  .stream :global(.meta-left) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px;
  }
  .stream :global(.type) {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
  }
  .stream :global(.type-note) { color: var(--note); }
  .stream :global(.type-reading) { color: var(--reading); }
  .stream :global(.type-photo) { color: var(--photo); }
  .stream :global(.type-link) { color: var(--link); }
  .stream :global(.tags),
  .stream :global(time) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }
  .stream :global(.source) {
    font-size: 12px;
    color: var(--muted);
  }
  .stream :global(.title) {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.45;
    color: var(--ink);
  }
  .stream :global(.excerpt) {
    margin-top: 8px;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
  }
</style>
