---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="search — stash" activeNav="search">
  <div class="search-box">
    <span class="search-icon">⌕</span>
    <input
      id="q"
      type="search"
      placeholder="search fragments…"
      autocomplete="off"
      autofocus
    />
    <span class="search-hint">
      <span id="count">—</span>
    </span>
  </div>

  <div class="tag-filter" id="tag-filter" hidden></div>

  <main class="stream" id="results"></main>

  <p class="empty" id="empty" hidden>no fragments match.</p>
  <p class="loading" id="loading">loading index…</p>
</BaseLayout>

<script>
  import MiniSearch from 'minisearch';
  import { tokenize } from '../lib/searchTokenize';

  type Entry = {
    id: string;
    type: 'note' | 'reading' | 'photo' | 'link';
    href: string;
    title: string;
    date: string;
    tags: string[];
    excerpt: string;
    source?: string;
    body: string;
    follows: string[];
  };

  const HOP_DEPTH = 2;

  const input = document.getElementById('q') as HTMLInputElement;
  const results = document.getElementById('results')!;
  const count = document.getElementById('count')!;
  const empty = document.getElementById('empty')!;
  const loading = document.getElementById('loading')!;
  const tagFilterEl = document.getElementById('tag-filter')!;

  let entries: Entry[] = [];
  const byId = new Map<string, Entry>();
  const childrenMap = new Map<string, string[]>();
  const htmlCache = new Map<string, string>();
  const itemByDomId = new Map<string, HTMLElement>();
  let mini: MiniSearch<Entry> | null = null;

  const INITIAL_TAG_LIMIT = 20;
  const selectedTags = new Set<string>();
  let tagCounts: Array<[string, number]> = [];
  let tagsExpanded = false;

  function escapeHtml(s: string): string {
    return s.replace(
      /[&<>"']/g,
      (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!),
    );
  }

  function domIdFor(entryId: string): string {
    return `item-${entryId.replace(/\//g, '-')}`;
  }

  function buildItem(e: Entry, index: number): HTMLElement {
    const art = document.createElement('article');
    art.className = 'item';
    art.id = domIdFor(e.id);
    art.dataset.id = e.id;
    art.style.order = String(index);

    const sourcePart =
      (e.type === 'reading' || e.type === 'link') && e.source
        ? `<span class="source">${escapeHtml(e.source)}</span>`
        : '';
    const tagsPart = e.tags.length
      ? `<span class="tags">${escapeHtml(e.tags.join('  '))}</span>`
      : '';
    const metaRight = [sourcePart, tagsPart]
      .filter(Boolean)
      .join('<span class="meta-sep" aria-hidden="true">/</span>');

    const excerptLine = e.excerpt ? `<p class="excerpt">${escapeHtml(e.excerpt)}</p>` : '';

    art.innerHTML = `
      <button class="item-header" type="button" aria-expanded="false" aria-controls="${domIdFor(e.id)}-body">
        <div class="meta">
          <div class="meta-left">
            <span class="type type-${e.type}">${e.type}</span>
            ${metaRight}
          </div>
          <time>${e.date}</time>
        </div>
        <h2 class="title">${escapeHtml(e.title)}</h2>
        ${excerptLine}
        <span class="toggle-indicator" aria-hidden="true">▾</span>
      </button>
      <section class="item-body" id="${domIdFor(e.id)}-body" hidden>
        <div class="item-content" data-content></div>
        <div class="item-footer">
          <a class="permalink" href="${e.href}">個別ページで開く →</a>
        </div>
        <div class="item-minigraph" data-minigraph></div>
      </section>
    `;

    const header = art.querySelector('.item-header') as HTMLButtonElement;
    header.addEventListener('click', () => toggleItem(art));
    return art;
  }

  async function toggleItem(art: HTMLElement): Promise<void> {
    const header = art.querySelector('.item-header') as HTMLButtonElement;
    const body = art.querySelector('.item-body') as HTMLElement;
    const isOpen = header.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      header.setAttribute('aria-expanded', 'false');
      body.hidden = true;
      return;
    }
    header.setAttribute('aria-expanded', 'true');
    body.hidden = false;

    const id = art.dataset.id!;
    const entry = byId.get(id);
    if (!entry) return;

    const contentEl = art.querySelector('[data-content]') as HTMLElement;
    if (!contentEl.dataset.loaded) {
      contentEl.innerHTML = '<p class="content-placeholder">loading…</p>';
      try {
        const html = await fetchDetailContent(entry.href);
        contentEl.innerHTML = html;
        contentEl.dataset.loaded = '1';
      } catch {
        contentEl.innerHTML = '<p class="content-placeholder">failed to load.</p>';
      }
    }

    const graphEl = art.querySelector('[data-minigraph]') as HTMLElement;
    if (!graphEl.dataset.rendered) {
      graphEl.innerHTML = renderMiniGraph(id, graphEl.clientWidth);
      graphEl.dataset.rendered = '1';
      graphEl.querySelectorAll<HTMLElement>('[data-target]').forEach((el) => {
        el.addEventListener('click', (ev) => {
          ev.preventDefault();
          const target = el.dataset.target;
          if (target) jumpTo(target);
        });
      });
    }
  }

  async function fetchDetailContent(href: string): Promise<string> {
    if (htmlCache.has(href)) return htmlCache.get(href)!;
    const res = await fetch(href);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const text = await res.text();
    const doc = new DOMParser().parseFromString(text, 'text/html');
    const article = doc.querySelector('article.detail');
    if (!article) throw new Error('detail not found');
    article.querySelectorAll('.meta, .title, .follows, .tags').forEach((el) => el.remove());
    const html = article.innerHTML.trim();
    htmlCache.set(href, html);
    return html;
  }

  type SubgraphNode = Entry;
  type SubgraphEdge = { from: string; to: string };

  function buildSubgraph(centerId: string, depth: number): { nodes: SubgraphNode[]; edges: SubgraphEdge[] } {
    const visited = new Set<string>();
    visited.add(centerId);
    let frontier = [centerId];
    for (let d = 0; d < depth; d++) {
      const next: string[] = [];
      for (const id of frontier) {
        const e = byId.get(id);
        if (!e) continue;
        for (const p of e.follows) {
          if (byId.has(p) && !visited.has(p)) {
            visited.add(p);
            next.push(p);
          }
        }
        for (const c of childrenMap.get(id) ?? []) {
          if (!visited.has(c)) {
            visited.add(c);
            next.push(c);
          }
        }
      }
      if (next.length === 0) break;
      frontier = next;
    }
    const nodes: SubgraphNode[] = [];
    for (const id of visited) {
      const e = byId.get(id);
      if (e) nodes.push(e);
    }
    const edges: SubgraphEdge[] = [];
    for (const n of nodes) {
      for (const p of n.follows) {
        if (visited.has(p)) edges.push({ from: p, to: n.id });
      }
    }
    return { nodes, edges };
  }

  function renderMiniGraph(centerId: string, availableWidth: number): string {
    const { nodes, edges } = buildSubgraph(centerId, HOP_DEPTH);
    if (nodes.length <= 1) {
      return '<p class="minigraph-empty">このメモにつながっている他のメモはありません。</p>';
    }

    // newer on the left (date desc)
    nodes.sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : a.id < b.id ? -1 : 1));

    const paddingX = 48;
    const minSpacing = 180;
    const height = 108;
    const y = height / 2;
    const radius = 6;
    const centerRadius = 9;

    const naturalWidth = paddingX * 2 + Math.max(0, nodes.length - 1) * minSpacing;
    const width = Math.max(naturalWidth, availableWidth || naturalWidth);
    const spacing = nodes.length > 1 ? (width - paddingX * 2) / (nodes.length - 1) : 0;

    const xByKey = new Map<string, number>();
    nodes.forEach((n, i) => xByKey.set(n.id, paddingX + i * spacing));

    const edgePath = (x1: number, x2: number): string => {
      const dx = (x2 - x1) * 0.5;
      return `M ${x1.toFixed(2)} ${y} C ${(x1 + dx).toFixed(2)} ${y} ${(x2 - dx).toFixed(2)} ${y} ${x2.toFixed(2)} ${y}`;
    };

    const edgeMarkup = edges
      .map((e) => {
        const x1 = xByKey.get(e.from);
        const x2 = xByKey.get(e.to);
        if (x1 === undefined || x2 === undefined) return '';
        return `<path class="mini-edge" d="${edgePath(x1, x2)}" />`;
      })
      .join('');

    const shortTitle = (t: string): string => (t.length > 14 ? `${t.slice(0, 13)}…` : t);

    const anchorFor = (i: number): string => {
      if (i === 0) return 'start';
      if (i === nodes.length - 1) return 'end';
      return 'middle';
    };

    const nodeMarkup = nodes
      .map((n, i) => {
        const x = xByKey.get(n.id)!;
        const isCenter = n.id === centerId;
        const r = isCenter ? centerRadius : radius;
        const classes = ['mini-node', `mini-${n.type}`];
        if (isCenter) classes.push('mini-center');
        const label = escapeHtml(shortTitle(n.title));
        const fullTitle = escapeHtml(`${n.title} — ${n.date}`);
        const anchor = anchorFor(i);
        return `
          <g class="${classes.join(' ')}" ${isCenter ? '' : `data-target="${n.id}"`} tabindex="${isCenter ? -1 : 0}" role="${isCenter ? 'img' : 'button'}">
            <circle cx="${x}" cy="${y}" r="${r}"></circle>
            <text x="${x}" y="${y - r - 10}" class="mini-label" text-anchor="${anchor}">${label}</text>
            <text x="${x}" y="${y + r + 16}" class="mini-date" text-anchor="${anchor}">${n.date}</text>
            <title>${fullTitle}</title>
          </g>`;
      })
      .join('');

    return `
      <div class="minigraph-heading">つながり</div>
      <div class="minigraph-direction" aria-hidden="true">
        <span>◀ recent</span>
        <span>older ▶</span>
      </div>
      <div class="minigraph-scroll">
        <svg viewBox="0 0 ${width} ${height}" width="${width}" height="${height}" class="minigraph-svg" role="img" aria-label="つながっているメモ">
          <g>${edgeMarkup}</g>
          <g>${nodeMarkup}</g>
        </svg>
      </div>
    `;
  }

  function jumpTo(entryId: string): void {
    const domId = domIdFor(entryId);
    const target = itemByDomId.get(domId);
    if (!target) return;
    if (target.hidden) {
      input.value = '';
      applyFilter();
    }
    const header = target.querySelector('.item-header') as HTMLButtonElement;
    const expanded = header.getAttribute('aria-expanded') === 'true';
    if (!expanded) {
      void toggleItem(target);
    }
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function matchesSelectedTags(e: Entry): boolean {
    for (const t of selectedTags) {
      if (!e.tags.includes(t)) return false;
    }
    return true;
  }

  function applyFilter(): void {
    if (!mini) return;
    const q = input.value.trim();
    const hasQuery = q.length > 0;
    const hasTags = selectedTags.size > 0;

    if (!hasQuery && !hasTags) {
      let i = 0;
      for (const e of entries) {
        const el = itemByDomId.get(domIdFor(e.id));
        if (!el) continue;
        el.hidden = false;
        el.style.order = String(i++);
      }
      count.textContent = String(entries.length);
      empty.hidden = entries.length > 0;
      return;
    }

    let orderedIds: string[];
    if (hasQuery) {
      const hits = mini.search(q);
      orderedIds = hits.map((h) => String(h.id));
      if (hasTags) {
        orderedIds = orderedIds.filter((id) => {
          const e = byId.get(id);
          return e ? matchesSelectedTags(e) : false;
        });
      }
    } else {
      orderedIds = entries.filter(matchesSelectedTags).map((e) => e.id);
    }

    const matched = new Set(orderedIds);
    orderedIds.forEach((id, rank) => {
      const el = itemByDomId.get(domIdFor(id));
      if (el) {
        el.hidden = false;
        el.style.order = String(rank);
      }
    });
    let trailing = orderedIds.length;
    for (const e of entries) {
      if (matched.has(e.id)) continue;
      const el = itemByDomId.get(domIdFor(e.id));
      if (!el) continue;
      el.hidden = true;
      el.style.order = String(trailing++);
    }
    count.textContent = String(matched.size);
    empty.hidden = matched.size > 0;
  }

  function renderTagFilter(): void {
    if (tagCounts.length === 0) {
      tagFilterEl.hidden = true;
      tagFilterEl.innerHTML = '';
      return;
    }
    tagFilterEl.hidden = false;

    const hiddenCount = Math.max(0, tagCounts.length - INITIAL_TAG_LIMIT);
    const visible = tagsExpanded ? tagCounts : tagCounts.slice(0, INITIAL_TAG_LIMIT);
    const extras: string[] = [];
    if (!tagsExpanded) {
      for (const t of selectedTags) {
        if (!visible.some(([tag]) => tag === t)) {
          const c = tagCounts.find(([tag]) => tag === t)?.[1] ?? 0;
          extras.push(`<button type="button" class="tag-chip is-active" data-tag="${escapeHtml(t)}" aria-pressed="true">${escapeHtml(t)}<span class="tag-count">${c}</span></button>`);
        }
      }
    }

    const chips = visible
      .map(([t, c]) => {
        const active = selectedTags.has(t);
        return `<button type="button" class="tag-chip${active ? ' is-active' : ''}" data-tag="${escapeHtml(t)}" aria-pressed="${active}">${escapeHtml(t)}<span class="tag-count">${c}</span></button>`;
      })
      .join('');

    const more = hiddenCount > 0
      ? `<button type="button" class="tag-more" data-role="tag-more">${tagsExpanded ? '− less' : `+ ${hiddenCount} more`}</button>`
      : '';

    const clear = selectedTags.size > 0
      ? `<button type="button" class="tag-clear" data-role="tag-clear">clear</button>`
      : '';

    tagFilterEl.innerHTML = extras.join('') + chips + more + clear;

    tagFilterEl.querySelectorAll<HTMLButtonElement>('.tag-chip').forEach((btn) => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tag!;
        if (selectedTags.has(t)) selectedTags.delete(t);
        else selectedTags.add(t);
        renderTagFilter();
        applyFilter();
      });
    });
    tagFilterEl.querySelector<HTMLButtonElement>('[data-role="tag-more"]')?.addEventListener('click', () => {
      tagsExpanded = !tagsExpanded;
      renderTagFilter();
    });
    tagFilterEl.querySelector<HTMLButtonElement>('[data-role="tag-clear"]')?.addEventListener('click', () => {
      selectedTags.clear();
      renderTagFilter();
      applyFilter();
    });
  }

  function renderAll(): void {
    results.innerHTML = '';
    itemByDomId.clear();
    const frag = document.createDocumentFragment();
    entries.forEach((e, i) => {
      const el = buildItem(e, i);
      itemByDomId.set(el.id, el);
      frag.appendChild(el);
    });
    results.appendChild(frag);
  }

  async function init(): Promise<void> {
    const res = await fetch('/search-index.json');
    entries = (await res.json()) as Entry[];
    for (const e of entries) byId.set(e.id, e);
    for (const e of entries) {
      for (const p of e.follows) {
        const arr = childrenMap.get(p);
        if (arr) arr.push(e.id);
        else childrenMap.set(p, [e.id]);
      }
    }

    mini = new MiniSearch<Entry>({
      idField: 'id',
      fields: ['title', 'tags', 'source', 'body'],
      storeFields: ['id'],
      tokenize: (text) => tokenize(text),
      processTerm: (t) => t,
      extractField: (doc, fieldName) => {
        const v = (doc as unknown as Record<string, unknown>)[fieldName];
        if (Array.isArray(v)) return v.join(' ');
        return typeof v === 'string' ? v : '';
      },
      searchOptions: {
        boost: { title: 3, tags: 2, source: 2, body: 1 },
        fuzzy: 0.2,
        prefix: true,
        combineWith: 'AND',
      },
    });
    mini.addAll(entries);

    const counts = new Map<string, number>();
    for (const e of entries) {
      for (const t of e.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
    }
    tagCounts = [...counts.entries()].sort((a, b) =>
      b[1] - a[1] || a[0].localeCompare(b[0]),
    );

    renderAll();
    renderTagFilter();
    loading.hidden = true;
    count.textContent = String(entries.length);
    applyFilter();
  }

  input.addEventListener('input', applyFilter);
  init().catch((err) => {
    loading.textContent = 'failed to load index.';
    console.error(err);
  });
</script>

<style>
  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    margin-bottom: 28px;
  }
  .search-icon {
    font-family: var(--mono);
    font-size: 16px;
    color: var(--faint);
  }
  #q {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font: inherit;
    font-size: 15px;
    color: var(--ink);
  }
  #q::placeholder {
    color: var(--faint);
  }
  .search-hint {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faintest);
  }
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: -12px 0 24px;
  }
  .tag-filter :global(.tag-chip) {
    all: unset;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 4px 10px;
    border: 1px solid var(--hairline);
    border-radius: 2px;
    background: var(--surface);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    cursor: pointer;
  }
  .tag-filter :global(.tag-chip:hover) {
    color: var(--ink);
    border-color: var(--ink-soft);
  }
  .tag-filter :global(.tag-chip:focus-visible) {
    outline: 2px solid var(--ink);
    outline-offset: 1px;
  }
  .tag-filter :global(.tag-chip.is-active) {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--surface);
  }
  .tag-filter :global(.tag-count) {
    font-size: 10px;
    color: var(--faint);
  }
  .tag-filter :global(.tag-chip.is-active .tag-count) {
    color: var(--surface);
    opacity: 0.7;
  }
  .tag-filter :global(.tag-more),
  .tag-filter :global(.tag-clear) {
    all: unset;
    padding: 4px 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    cursor: pointer;
  }
  .tag-filter :global(.tag-more:hover),
  .tag-filter :global(.tag-clear:hover) {
    color: var(--ink);
  }

  .stream {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--hairline);
  }
  .stream:empty {
    border-bottom: none;
  }
  .empty,
  .loading {
    padding: 48px 0;
    text-align: center;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
  }

  /* accordion item */
  .stream :global(.item) {
    border-top: 1px solid var(--hairline);
  }
  .stream :global(.item[hidden]) {
    display: none;
  }
  .stream :global(.item-header) {
    all: unset;
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 24px 20px 24px 0;
    cursor: pointer;
    position: relative;
    color: var(--ink);
  }
  .stream :global(.item-header:hover) {
    background: rgba(255, 255, 255, 0.5);
  }
  .stream :global(.item-header:focus-visible) {
    outline: 2px solid var(--ink);
    outline-offset: -2px;
  }
  .stream :global(.meta) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 8px;
  }
  .stream :global(.meta-left) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px;
  }
  .stream :global(.type) {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
  }
  .stream :global(.type-note) { color: var(--note); }
  .stream :global(.type-reading) { color: var(--reading); }
  .stream :global(.type-photo) { color: var(--photo); }
  .stream :global(.type-link) { color: var(--link); }
  .stream :global(.tags),
  .stream :global(.item-header time) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }
  .stream :global(.source) {
    font-size: 12px;
    color: var(--muted);
  }
  .stream :global(.meta-sep) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faintest);
  }
  .stream :global(.title) {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
  }
  .stream :global(.excerpt) {
    margin-top: 8px;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
  }
  .stream :global(.toggle-indicator) {
    position: absolute;
    top: 24px;
    right: 4px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    transition: transform 0.15s ease;
  }
  .stream :global(.item-header[aria-expanded='true'] .toggle-indicator) {
    transform: rotate(180deg);
  }
  .stream :global(.item-header[aria-expanded='true']) {
    padding-bottom: 8px;
  }
  .stream :global(.item-header[aria-expanded='true'] .excerpt) {
    display: none;
  }

  /* expanded body */
  .stream :global(.item-body) {
    padding: 0 0 28px;
  }
  .stream :global(.content-placeholder) {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
    padding: 16px 0;
  }

  /* reused typography / media */
  .stream :global(.item-content) {
    font-size: 15px;
    line-height: 1.85;
    color: var(--ink-soft);
  }
  .stream :global(.item-content p) { margin: 14px 0; }
  .stream :global(.item-content h2) {
    margin: 24px 0 10px;
    font-size: 17px;
    font-weight: 600;
    color: var(--ink);
  }
  .stream :global(.item-content h3) {
    margin: 18px 0 6px;
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
  }
  .stream :global(.item-content img) {
    max-width: 100%;
    height: auto;
    border-radius: 2px;
  }
  .stream :global(.item-content blockquote) {
    border-left: 2px solid var(--hairline);
    margin: 16px 0;
    padding: 4px 16px;
    color: var(--muted);
    font-style: italic;
  }
  .stream :global(.item-content code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--surface);
    padding: 2px 5px;
    border-radius: 2px;
  }
  .stream :global(.item-content pre) {
