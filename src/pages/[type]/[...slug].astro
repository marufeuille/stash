---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const photos = await getCollection('photo');
  const readings = await getCollection('reading');
  const notes = await getCollection('note');
  const links = await getCollection('link');

  const allPosts = [...photos, ...readings, ...notes, ...links].filter((post) => !post.data.draft);

  return allPosts.map((post) => ({
    params: { type: post.data.type, slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.date.toISOString().slice(0, 10);
let linkHost: string | null = null;
let linkDisplayUrl: string | null = null;
if (post.data.type === 'link') {
  try {
    const u = new URL(post.data.url);
    linkHost = u.hostname.replace(/^www\./, '');
    linkDisplayUrl = (linkHost + u.pathname + u.search).replace(/\/$/, '');
  } catch {
    linkHost = null;
    linkDisplayUrl = post.data.url;
  }
}
const displayTitle =
  post.data.title ||
  (post.data.type === 'reading'
    ? post.data.book
    : post.data.type === 'link'
      ? (linkHost ?? 'Untitled')
      : 'Untitled');
const activeNav = post.data.type as 'note' | 'reading' | 'photo' | 'link';
---

<BaseLayout title={`${displayTitle} — stash`} activeNav={activeNav}>
  <article class="detail">
    <div class="meta">
      <span class={`type type-${post.data.type}`}>{post.data.type}</span>
      <time datetime={dateStr}>{dateStr}</time>
    </div>

    <h1 class="title">{displayTitle}</h1>

    {post.data.type === 'reading' && (
      <div class="source">
        <span class="book">{post.data.book}</span>
        <span class="author"> — {post.data.author}</span>
        {post.data.progress && <span class="progress">{post.data.progress}</span>}
      </div>
    )}

    {post.data.type === 'photo' && (
      <div class="photo">
        <Image src={post.data.image} alt={post.data.alt} format="webp" />
      </div>
    )}

    {post.data.type === 'link' && (
      <a class="link-out" href={post.data.url} target="_blank" rel="noopener noreferrer">
        <span class="link-arrow" aria-hidden="true">→</span>
        <span class="link-url">{linkDisplayUrl ?? post.data.url}</span>
      </a>
    )}

    {post.data.type === 'link' && post.data.quote && (
      <blockquote class="link-quote">{post.data.quote}</blockquote>
    )}

    {post.data.tags.length > 0 && (
      <div class="tags">{post.data.tags.join('  ')}</div>
    )}

    <div class="body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .detail {
    padding-top: 8px;
  }
  .meta {
    display: flex;
    gap: 12px;
    align-items: baseline;
    margin-bottom: 12px;
  }
  .type {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
  }
  .type-note { color: var(--note); }
  .type-reading { color: var(--reading); }
  .type-photo { color: var(--photo); }
  .type-link { color: var(--link); }
  time {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }
  .title {
    font-size: 28px;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
  }
  .source {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .source .author { color: var(--faint); }
  .source .progress {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    margin-left: 8px;
  }
  .photo {
    margin: 20px 0;
  }
  .photo :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }
  .link-out {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 14px 16px;
    margin: 4px 0 16px;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    color: var(--ink);
    font-size: 14px;
    line-height: 1.5;
    transition: border-color 0.15s ease;
    word-break: break-all;
  }
  .link-out:hover {
    border-color: var(--link);
  }
  .link-arrow {
    font-family: var(--mono);
    color: var(--link);
    flex-shrink: 0;
  }
  .link-url {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-soft);
  }
  .link-quote {
    margin: 0 0 24px;
    padding: 4px 16px;
    border-left: 2px solid var(--hairline);
    color: var(--muted);
    font-style: italic;
    font-size: 14px;
    line-height: 1.75;
  }
  .tags {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
    margin-bottom: 28px;
  }
  .body {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--hairline);
    font-size: 15px;
    line-height: 1.85;
    color: var(--ink-soft);
  }
  .body :global(p) { margin: 14px 0; }
  .body :global(h2) {
    margin: 28px 0 12px;
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
  }
  .body :global(h3) {
    margin: 20px 0 8px;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
  }
  .body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 2px;
  }
  .body :global(blockquote) {
    border-left: 2px solid var(--hairline);
    margin: 16px 0;
    padding: 4px 16px;
    color: var(--muted);
    font-style: italic;
  }
  .body :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--surface);
    padding: 2px 5px;
    border-radius: 2px;
  }
  .body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    padding: 14px 16px;
    overflow-x: auto;
  }
  .body :global(pre code) {
    background: transparent;
    padding: 0;
  }
  .body :global(a) {
    color: var(--ink);
    border-bottom: 1px solid var(--hairline);
  }
  .body :global(a:hover) {
    border-bottom-color: var(--ink);
  }
</style>
